# grey-hat-security-agent .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ============================================================
# LLM Provider Configuration
# ============================================================

# Primary LLM provider: "claude" | "openai" | "ollama"
LLM_PROVIDER=claude

# Anthropic Claude API Key
# Signup: https://console.anthropic.com/
# Pricing: https://www.anthropic.com/pricing
# Models: claude-opus-4-8, claude-sonnet-4-8, claude-haiku-3-5
CLAUDE_API_KEY=

# OpenAI GPT-4o API Key (fallback provider)
# Signup: https://platform.openai.com/signup
# Pricing: https://openai.com/pricing
# Models: gpt-4o, gpt-4o-mini
OPENAI_API_KEY=

# Ollama Local LLM Configuration (offline fallback)
# Install: https://ollama.ai/download
# Models: mistral:7b-instruct, mistral:7b-instruct-v0.3
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# Threat Intelligence APIs
# ============================================================

# VirusTotal API Key
# Signup: https://www.virustotal.com/gui/join-us
# Free tier: 4 req/min, 500 req/day
# Paid tier: Contact sales for higher limits
VIRUSTOTAL_API_KEY=

# Shodan API Key
# Signup: https://account.shodan.io/register
# Free tier: 100 searches/month, 1 req/sec
# Membership: /year (100 searches/day)
SHODAN_API_KEY=

# NVD (National Vulnerability Database) API Key
# Signup: https://nvd.nist.gov/developers/request-an-api-key
# Free: 5 req/30sec without key, 50 req/30sec with key
NVD_API_KEY=

# PhishTank API Key (optional for submissions)
# Signup: https://www.phishtank.com/developer_info.php
# Free for registered users
PHISHTANK_API_KEY=

# Google Safe Browsing API Key
# Signup: https://console.cloud.google.com (enable Safe Browsing API)
# Free: 10,000 queries/day
GOOGLE_SAFE_BROWSING_API_KEY=

# ============================================================
# Database Configuration
# ============================================================

# SQLite database path (relative to project root)
DB_PATH=data/grey_hat_agent.db

# AES-256-GCM encryption key for database fields
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Change this for production!
ENCRYPTION_KEY=

# ============================================================
# Scanning Configuration
# ============================================================

# Path to nmap binary
# Install: https://nmap.org/download.html
NMAP_PATH=/usr/bin/nmap

# OWASP ZAP API URL (when running in daemon mode)
# Install: https://www.zaproxy.org/download/
# Docker: docker run -u zap -p 8080:8080 -p 8090:8090 zaproxy/zap-stable
ZAP_API_URL=http://localhost:8090
ZAP_API_KEY=

# ============================================================
# Application Settings
# ============================================================

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Rate limiting (requests per minute for external APIs)
RATE_LIMIT_VIRUSTOTAL=4
RATE_LIMIT_SHODAN=60
RATE_LIMIT_NVD=100

# Domain risk score weights (must sum to 1.0)
RISK_WEIGHT_VT=0.30
RISK_WEIGHT_FEEDS=0.20
RISK_WEIGHT_NLP=0.25
RISK_WEIGHT_AGE=0.15
RISK_WEIGHT_WHOIS=0.10

# Report output directory
REPORT_OUTPUT_DIR=data/reports

# Knowledge base update schedule (cron format)
KNOWLEDGE_UPDATE_CRON=0 2 * * 0
